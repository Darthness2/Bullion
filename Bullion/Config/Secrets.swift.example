//  Secrets.swift.example
//  Copy to Secrets.swift and fill in the values.
//  Secrets.swift is gitignored — never commit real values.
//
//  Bullion uses Plaid for brokerage linking. Plaid's client_id and secret
//  stay on the backend server — they never touch the app. The only value
//  the app needs is the OAuth callback scheme, which must match Info.plist's
//  CFBundleURLSchemes.

enum Secrets {
    /// Custom URL scheme used for the Plaid Link OAuth callback.
    static let plaidCallbackScheme = "bullion"
}