//  Secrets.swift.example
//  Copy to Secrets.swift and fill in the values.
//  Secrets.swift is gitignored — never commit real values.
//
//  NOTE: Bullion is backend-less. Yahoo Finance needs no API key. SnapTrade
//  credentials (clientId / consumerKey) are entered in the app
//  (Settings → Advanced → Brokerage) and stored in the iOS Keychain — they
//  are NOT compiled in here. The only value the app needs is the OAuth
//  callback scheme, which must match Info.plist's CFBundleURLSchemes and the
//  redirect URI whitelisted in your SnapTrade dashboard.

enum Secrets {
    /// Custom URL scheme used for the SnapTrade Connection Portal callback.
    static let snaptradeCallbackScheme = "ledger"
}
