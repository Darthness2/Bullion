//  Secrets.swift.example
//  Copy to Secrets.swift and fill in your backend URL.
//  Secrets.swift is gitignored — never commit real values.
//
//  NOTE: Yahoo Finance needs no API key. SnapTrade consumerKey stays
//  on the backend. The app only needs the backend URL.
//
//  backendBaseURL can be:
//    - http://localhost:8787              (local Express dev server)
//    - https://bullion-backend.vercel.app (Vercel serverless deployment)
//    - https://bullion-backend.onrender.com (Render always-on deployment)
//  A backend IS required for SnapTrade — the consumerKey can't ship in the
//  app. Market data (Yahoo) needs no backend.

enum Secrets {
    static let backendBaseURL = "http://127.0.0.1:8787"
    static let snaptradeCallbackScheme = "ledger"

    /// Shared bearer token for the backend's /snaptrade endpoints. Must match
    /// `BULLION_API_TOKEN` in the backend's env. Leave empty for local dev
    /// (the backend then runs unauthenticated). Set a long random string when
    /// deploying to lock down the endpoints.
    static let backendAPIToken = ""
}