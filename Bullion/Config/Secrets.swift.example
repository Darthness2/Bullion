//  Secrets.swift.example
//  Copy to Secrets.swift and fill in your backend URL.
//  Secrets.swift is gitignored — never commit real values.
//
//  NOTE: Yahoo Finance needs no API key. SnapTrade consumerKey stays
//  on the backend. The app only needs the backend URL.

enum Secrets {
    static let backendBaseURL = "http://localhost:8787"
    static let snaptradeCallbackScheme = "ledger"

    /// Shared bearer token for the backend's /snaptrade endpoints. Must match
    /// `BULLION_API_TOKEN` in the backend's .env. Leave empty for local dev
    /// (the backend then runs unauthenticated).
    static let backendAPIToken = ""
}