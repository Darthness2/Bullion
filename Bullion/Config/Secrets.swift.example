//  Secrets.swift.example
//  Copy to Secrets.swift and fill in the values.
//  Secrets.swift is gitignored — never commit real values.
//
//  NOTE: Yahoo Finance needs no API key. SnapTrade is now backend-less —
//  enter your SnapTrade clientId/consumerKey in the app (Settings →
//  Brokerage); they're stored in the Keychain. The only value the app needs
//  here is the OAuth callback scheme, which must match the URL scheme
//  registered in Info.plist and the redirect URI whitelisted in SnapTrade.

enum Secrets {
    /// Custom URL scheme used for the SnapTrade Connection Portal callback.
    /// Must match Info.plist CFBundleURLSchemes and your SnapTrade redirect URI.
    static let snaptradeCallbackScheme = "ledger"
}
