# Bullion backend environment variables.
# Copy to .env and fill in. Never commit the real .env.
# You already have these keys in ~/.config/snaptrade/settings.json

# SnapTrade (from https://dashboard.snaptrade.com/api-key)
SNAPTRADE_CLIENT_ID=PERS-MR3OJWQ2AKTNQILSKUL4
SNAPTRADE_CONSUMER_KEY=your-consumer-key-here
SNAPTRADE_USER_ID=snaptrade-cli-meteteoman
SNAPTRADE_USER_SECRET=your-user-secret-here

# Market data: Yahoo Finance (no key needed, no rate limit).
# No API key required — the app calls Yahoo Finance directly.

# Server
PORT=8787
CORS_ORIGIN=*

# Redirect URI scheme registered in the iOS app Info.plist
SNAPTRADE_REDIRECT_URI=ledger://snaptrade-callback