# Plaid API credentials (get these from https://dashboard.plaid.com)
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_secret_here
PLAID_ENV=sandbox

# Server config
PORT=8787
# Comma-separated list of allowed origins (the app's bundle ID scheme or your domain)
# For development: http://localhost:*,capacitor://*, your app's scheme
CORS_ORIGIN=*